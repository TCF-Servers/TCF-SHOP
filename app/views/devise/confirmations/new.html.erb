<div class="auth-heading">
  <h2>Renvoyer la confirmation</h2>
  <p>Entrez votre email pour recevoir à nouveau les instructions de confirmation.</p>
</div>

<%= simple_form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, class: "auth-form" }) do |f| %>
  <%= f.error_notification %>
  <%= f.full_error :confirmation_token %>

  <%= f.input :email,
              label: "Email",
              required: true,
              autofocus: true,
              value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
              input_html: { autocomplete: "email" } %>

  <div class="auth-actions">
    <%= f.button :submit, "Renvoyer les instructions", class: "btn auth-btn-primary" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
