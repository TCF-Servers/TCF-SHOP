<div class="auth-links">
  <% if controller_name != 'sessions' %>
    <%= link_to "Déjà un compte ? Se connecter", new_session_path(resource_name), class: "auth-link" %>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Pas encore de compte ? Créer un compte", new_registration_path(resource_name), class: "auth-link" %>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Mot de passe oublié ?", new_password_path(resource_name), class: "auth-link auth-link-muted" %>
  <% end %>

  <% if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "Renvoyer les instructions de confirmation", new_confirmation_path(resource_name), class: "auth-link auth-link-muted" %>
  <% end %>

  <% if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "Renvoyer les instructions de déverrouillage", new_unlock_path(resource_name), class: "auth-link auth-link-muted" %>
  <% end %>
</div>
