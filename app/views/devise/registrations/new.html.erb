<div class="auth-heading">
  <h2>Créer un compte</h2>
  <p>Renseignez votre pseudo en jeu pour lier votre compte à votre personnage.</p>
</div>

<%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
  <%= f.error_notification %>

  <%= f.input :email,
              label: "Email",
              required: true,
              autofocus: true,
              input_html: { autocomplete: "email" } %>

  <%= f.input :in_game_name,
              label: "Pseudo en jeu",
              required: false,
              hint: "Pseudo de votre personnage sur le serveur. Vous pouvez le renseigner plus tard.",
              input_html: { autocomplete: "off" } %>

  <%= f.input :password,
              label: "Mot de passe",
              required: true,
              hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
              input_html: { autocomplete: "new-password" } %>

  <%= f.input :password_confirmation,
              label: "Confirmer le mot de passe",
              required: true,
              input_html: { autocomplete: "new-password" } %>

  <div class="auth-actions">
    <%= f.button :submit, "Créer mon compte", class: "btn auth-btn-primary" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
